   ],
   "source": [
    "from scipy import stats\n",
    "\n",
    "alpha = 0.1\n",
    "beta = 0.25\n",
    "mde = 0.02\n",
    "std = 0.49\n",
    "\n",
    "z = stats.norm.ppf(q=1 - alpha) + stats.norm.ppf(q=1 - beta)\n",
    "size = 2 * (std * z / mde) ** 2\n",
    "\n",
    "print(f\"Необходимое количество пользователей в контрольной и тестовой группах: {round(size) + 1}\")"
   ]
  },
